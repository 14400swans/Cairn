# Secrets — never commit these
.env
*.env
!.env.example

# Cairn's local governance state (per-machine, not shared)
.cairn_write_state.json

# DataHub quickstart infrastructure (generated locally by
# `datahub docker quickstart` / `datahub docker ingest-sample-data`,
# lives under ~/.datahub/ — not part of this project, and machine-specific
# if it ever ends up copied or symlinked into the repo by mistake)
.datahub/
docker-compose.yml

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# Editors
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

services.txt
docker-comp*