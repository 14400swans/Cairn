# --- DataHub MCP Server connection ---
# Self-hosted quickstart default; change for DataHub Cloud
#
# VERIFIED 2026-07-13/14: `mcp-server-datahub --transport http` bound to
# port 8000 in local testing, not the 8080 shown in earlier drafts of
# this file (8080 is DataHub's own GMS port -- a different service,
# see DATAHUB_GMS_URL below -- not the MCP server's port). The MCP
# server's own startup log line always shows the real port it bound to
# (`Uvicorn running on http://127.0.0.1:PORT`) -- check that and make
# sure the port below matches it exactly before your first run.
DATAHUB_MCP_URL=http://localhost:8000/mcp
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_PERSONAL_ACCESS_TOKEN=

# --- IMPORTANT: writes are disabled by default on the MCP server ---
# You must set this to true on the MCP SERVER side (not here) for
# add_structured_properties / update_description / save_document to work.
# See: docs.datahub.com MCP Server Guide -> TOOLS_IS_MUTATION_ENABLED
# TOOLS_IS_MUTATION_ENABLED=true

# --- Cairn governance settings ---
CAIRN_MIN_CONFIDENCE_TO_WRITE=0.55
CAIRN_COOLDOWN_HOURS=24
CAIRN_MAX_WRITES_PER_RUN=10

# --- LLM (used by Sentinel to reason over schema/lineage/query text) ---
# Only needed for Sentinel._find_documentation_gaps -- it degrades
# gracefully (logs + returns no findings) if this is left empty, rather
# than erroring. Requires `pip install anthropic` (or `pip install
# cairn[llm]`) -- see pyproject.toml.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=